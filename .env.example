# Copy to .env (gitignored) and fill in. The backend reads these via backend/config.py.

# Required for scene generation. Get a key at https://gizmo.antimlabs.com
GIZMO_API_KEY=

# Required for the vision step (photo -> scene description). Default provider is the
# Google AI Studio (Gemini) API running gemma-3-12b-it. Get a key at aistudio.google.com.
GOOGLE_API_KEY=

# Demo mode: skip the Gizmo POST (generate + export) and use a local scene as the
# "export" so everything after the POST runs offline (the progress bar still animates
# via mock events). No GIZMO_API_KEY needed in this mode.
# HUDATHON_DEMO_MODE=1
# HUDATHON_DEMO_SCENE=env2          # folder under scenes/ to use as the mock export

# Optional overrides (defaults shown):
# GIZMO_BASE_URL=https://api.gizmo.antimlabs.com
# HUDATHON_VISION_PROVIDER=google          # "google" (Gemini API) or "ollama" (local)
# HUDATHON_VISION_MODEL=gemma-3-12b-it      # google model id
# OLLAMA_HOST=http://localhost:11434        # only used when HUDATHON_VISION_PROVIDER=ollama
# OLLAMA_MODEL=gemma3:12b
# HUDATHON_AGENT_MODEL=claude-sonnet-4-5   # the LLM that drives the gripper (via the HUD gateway)
# HUDATHON_TRAIN_ROUNDS=3                   # "train further" rounds
# HUDATHON_TRAIN_GROUP=3                    # rollouts per round
# HUDATHON_TRAIN_MODAL_DRY_RUN=1            # UI/API fine-tune: synthetic rewards, no Modal GPU

# The LLM tool-agent routes through the HUD gateway, so an HUD key is also needed
# for the rollout step (separate from scene generation):
# HUD_API_KEY=
